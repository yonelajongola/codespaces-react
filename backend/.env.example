# Backend Environment Variables

# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# Alternative: DATABASE_URL can be used instead of MONGO_URI
# DATABASE_URL=

# Server port (default: 3000)
PORT=3000

# JWT Secret for authentication tokens (REQUIRED in production!)
JWT_SECRET=your_secret_key_here_change_in_production

# CORS allowed origins (comma-separated for multiple origins)
# Use * for development, specify domains in production
CORS_ORIGIN=*

# Netlify flag (automatically set by Netlify, leave empty for local dev)
# NETLIFY=true
